# API
PORT=3002
JWT_SECRET=altere-em-producao

# Criptografia do ficheiro SQLite (opcional em dev; recomendado em produção).
# Se definido, o servidor abre novamart.db com esta chave.
# Para criptografar um .db antigo em texto claro: pare a API, faça backup, rode npm run db:encrypt
# SQLITE_ENCRYPTION_KEY=uma-chave-longa-e-secreta

# CORS: origem do front (produção pode ser lista separada por vírgula)
CORS_ORIGIN=http://localhost:5173

# SMTP (2FA e códigos por e-mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seudominio.com
