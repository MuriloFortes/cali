# API
PORT=3002
JWT_SECRET=altere-em-producao

# Criptografia do ficheiro SQLite (opcional em dev; recomendado em produção).
# Se definido, o servidor abre novamart.db com esta chave.
# Para criptografar um .db antigo em texto claro: pare a API, faça backup, rode npm run db:encrypt
# SQLITE_ENCRYPTION_KEY=uma-chave-longa-e-secreta

# CORS: origem do front (com http ou https). Lista separada por vírgula.
# Pode usar só o host/IP: o servidor aceita http e https para esse valor.
CORS_ORIGIN=http://localhost:5173

# WebAuthn (passkey / biometria no navegador)
# RP ID = hostname do site sem protocolo (ex.: loja.exemplo.com). Em dev: localhost
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NovaMart
# Defina 1 para pular WebAuthn e emitir JWT só com senha/2FA (útil sem HTTPS ou em IP cru)
# WEBAUTHN_DISABLED=1

# SMTP (2FA e códigos por e-mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seudominio.com

# Só testes/MVP: não envia e-mail; imprime o código 2FA no log do Node (nunca use em produção pública)
# EMAIL_2FA_LOG_ONLY=1
